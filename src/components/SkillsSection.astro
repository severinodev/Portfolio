---
import IconContainer from "@components/IconContainer.astro";
import Node from "@assets/icons/node.astro";
import Flutter from "@assets/icons/flutter.astro";
import Git from "@assets/icons/git.astro";
import Docker from "@assets/icons/docker.astro";
import Postman from "@assets/icons/postman.astro";
import Typescript from "@assets/icons/typescript.astro";
import Angular from "@assets/icons/angular.astro";
import Dotnet from "@assets/icons/dotnet.astro";
import React from "@assets/icons/react.astro";
import Postgresql from "@assets/icons/postgresql.astro";
---

<section class="my-20">
  <h2 class="text-2xl font-semibold mb-1">
    <span class="lang-es">Tecnologías y herramientas</span>
    <span class="lang-en">Technologies and Tools</span>
  </h2>
  <hr class="mb-6 border-zinc-600" />

  <h3 class="text-xl font-medium mb-4">Frontend</h3>
  <div style="display: flex; flex-wrap: wrap; gap: 20px;">
    <IconContainer name="Flutter">
      <Flutter size="size-9" />
    </IconContainer>
    <IconContainer name="Typescript">
      <Typescript size="size-9" />
    </IconContainer>
    <IconContainer name="Angular">
      <Angular size="size-9" />
    </IconContainer>
    <IconContainer name="React">
      <React size="size-9" />
    </IconContainer>
  </div>

  <h3 class="text-xl font-medium mt-6 mb-4">
    <span class="lang-es">Backend & Bases de Datos</span>
    <span class="lang-en">Backend & Databases</span>
  </h3>
  <div style="display: flex; flex-wrap: wrap; gap: 20px;">
    <IconContainer name=".NET Core">
      <Dotnet size="size-9" />
    </IconContainer>
    <IconContainer name="Node.js">
      <Node size="size-9" />
    </IconContainer>
    <IconContainer name="Postgresql">
      <Postgresql size="size-9" />
    </IconContainer>
  </div>

  <h3 class="text-xl font-medium mt-6 mb-4">
    <span class="lang-es">Herramientas</span>
    <span class="lang-en">Tools & CI/CD</span>
  </h3>
  <div style="display: flex; flex-wrap: wrap; gap: 20px;">
    <IconContainer name="Postman">
      <Postman size="size-9" />
    </IconContainer>
    <IconContainer name="Git">
      <Git size="size-9" />
    </IconContainer>
    <IconContainer name="Docker">
      <Docker size="size-9" />
    </IconContainer>
  </div>
</section>
