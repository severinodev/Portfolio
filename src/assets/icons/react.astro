---
// src/assets/icons/react.astro
const { size = "size-9" } = Astro.props;
---

<svg
  class={size}
  viewBox="0 0 256 256"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  {/* Átomo de React (Órbitas y núcleo) */}
  <g transform="translate(128, 128)">
    <circle cx="0" cy="0" r="16.5" fill="#00d8ff"></circle>
    <g stroke="#00d8ff" stroke-width="11" fill="none">
      <ellipse rx="84" ry="32"></ellipse>
      <ellipse rx="84" ry="32" transform="rotate(60)"></ellipse>
      <ellipse rx="84" ry="32" transform="rotate(120)"></ellipse>
    </g>
  </g>
</svg>
