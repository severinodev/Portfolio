---
const { size = "w-8 h-8" } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class={size}>
  <!-- Taza de café / Base -->
  <path fill="#E0E0E0" d="M39,26c0,5.52-4.48,10-10,10H15c-5.52,0-10-4.48-10-10v-9h34V26z"/>
  <!-- Asa de la taza -->
  <path fill="#E0E0E0" d="M37,20h3c2.21,0,4,1.79,4,4v0c0,2.21-1.79,4-4,4h-3V20z"/>
  <path fill="#BDBDBD" d="M37,22h3c1.1,0,2,0.9,2,2v0c0,1.1-0.9,2-2,2h-3V22z"/>
  <!-- Plato -->
  <path fill="#9E9E9E" d="M42,38H2c-1.1,0-2-0.9-2-2v0c0-1.1,0.9-2,2-2h40c1.1,0,2,0.9,2,2v0C44,37.1,43.1,38,42,38z"/>
  <!-- Líquido / Café -->
  <ellipse cx="22" cy="17" rx="14" ry="2" fill="#795548"/>
  <!-- Vapor / Rayas Rojas (Icono clásico de Java) -->
  <path fill="none" stroke="#F44336" stroke-width="3" stroke-linecap="round" stroke-miterlimit="10" d="M26,11c0,0-3-2-1-5s3-4,3-4"/>
  <path fill="none" stroke="#FF9800" stroke-width="3" stroke-linecap="round" stroke-miterlimit="10" d="M19,13c0,0-4-2-2-6s4-4,4-4"/>
