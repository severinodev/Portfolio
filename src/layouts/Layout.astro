---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

// Valores por defecto combinados con tus Props originales
const {
  title = "Elias Severino | Full-Stack Developer",
  description = "Portafolio profesional de desarrollo de software y documentación de proyectos. Diseñando experiencias web eficientes y modernas.",
  image = "/images/og-image.png",
} = Astro.props;

// Obtener la URL canónica de forma dinámica (necesita propiedad 'site' en astro.config.mjs)
const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://eliascvrno.vercel.app",
);
---

<!doctype html>
<html lang="es" id="html-root">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts originales -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&display=swap"
      rel="stylesheet"
    />

    <!-- Script original para persistencia de idioma con try/catch de seguridad -->
    <script is:inline>
      let savedLang = "es";
      try {
        savedLang = localStorage.getItem("lang") || "es";
      } catch (e) {
        // En caso de que localStorage esté deshabilitado por el navegador o restricciones de seguridad
      }
      document.documentElement.lang = savedLang;
    </script>

    <!-- URL Canónica -->
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO Primario -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Elias Severino" />
    <meta
      name="keywords"
      content="programador, full-stack, frontend, portfolio, astro, tailwind, desarrollo web, marca personal"
    />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />

    <!-- X / Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, canonicalURL)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Lora", serif;
    background-color: #181818;
    color: #fff;
  }

  /* Clases originales para el sistema multiidioma */
  html[lang="es"] .lang-en {
    display: none !important;
  }
  html[lang="en"] .lang-es {
    display: none !important;
  }
</style>
